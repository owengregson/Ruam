{
	"name": "ruam",
	"version": "2.0.0",
	"description": "JS VM obfuscator — compiles functions to custom bytecode executed by an embedded interpreter",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"import": "./dist/index.js",
			"types": "./dist/index.d.ts"
		}
	},
	"bin": {
		"ruam": "./dist/cli.js"
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsup",
		"build:browser": "node scripts/build-browser.mjs",
		"typecheck": "tsc --noEmit",
		"dev": "tsup --watch",
		"test": "vitest run",
		"test:watch": "vitest",
		"stats": "node scripts/collect-stats.mjs",
		"stats:test": "node scripts/collect-stats.mjs --test"
	},
	"engines": {
		"node": ">=18"
	},
	"license": "LGPL-2.1-only",
	"dependencies": {
		"@babel/generator": "^7.25.0",
		"@babel/parser": "^7.25.0",
		"@babel/traverse": "^7.25.0",
		"@babel/types": "^7.25.0",
		"@inquirer/prompts": "^8.3.0",
		"chalk": "^5.6.2",
		"fs-extra": "^11.2.0",
		"globby": "^14.0.2",
		"ora": "^9.3.0"
	},
	"devDependencies": {
		"@types/babel__generator": "^7.6.8",
		"@types/babel__traverse": "^7.20.6",
		"@types/fs-extra": "^11.0.4",
		"@types/node": "^20.14.0",
		"esbuild": "^0.27.4",
		"tsup": "^8.4.0",
		"typescript": "^5.7.0",
		"vitest": "^4.0.18"
	}
}
